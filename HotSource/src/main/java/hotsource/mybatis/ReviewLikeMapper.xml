<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ReviewLike">
	
	<sql id="columns">
		review_like_id, is_like, user_id, review_id
	</sql>
	
	<resultMap			type="ReviewLike"				id="joinMap">
		<id 					column="review_like_id"	property="review_like_id"/>
		<result				column="is_like"				property="is_like"/>
		<association	column="review_id"			property="review"		javaType="Review"		select="Review.select"/>
	</resultMap>
	
	<select id="selectByReviewId" resultMap="joinMap" parameterType="int">
		SELECT <include refid="columns"/> FROM review_like WHERE review_id=#{review_id}
	</select>
	
</mapper>