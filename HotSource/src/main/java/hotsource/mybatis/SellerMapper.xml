<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Seller">
	<sql id="columns">
		seller_id
		,user_id
		,seller_name
		,seller_nickname
		,seller_bio
		,profile_img_url
		,seller_insta_url
		,seller_email
		,bank_name
		,account_number
		,create_date
		,is_active
	</sql>
	
	<resultMap type="Seller" id="joinMap">
		<id 		column="seller_id" 	property="seller_id"/>
		<result 	column="seller_name" 			property="seller_name"/>
		
		<!-- 1:1 관계인 부모를 연계한다 -->
		<association column="user_id" 	property="user" javaType="User" select="User.select"/>
		<!-- 1:N 관계 -->
		<collection property="assetList" column="seller_id" javaType="java.util.List" ofType="Asset" select="Asset.selectBySellerId"/>
	</resultMap>
	
	<select id="selectAll" resultMap="joinMap">
		select <include refid="columns"/> from seller
	</select>
	
	<select id="selectBySellerId" parameterType="long" resultMap="joinMap">
		select <include refid="columns"/> from seller where seller_id = #{seller_id}
	</select>
	
	<select id="selectByUserId" parameterType="long" resultMap="joinMap">
		select <include refid="columns"/> from seller where user_id = #{user_id}
	</select>
	
		<!-- #{user.user_id}, profile_img_url이거로 변경해야 -->
	<insert id="insert" parameterType="Seller">
		insert into seller (
			user_id, seller_name, seller_nickname, seller_bio, seller_insta_url, seller_email, profile_img_url,
			bank_name, account_number, is_active
		)
		values (
			#{user.user_id}, #{seller_name}, #{seller_nickname}, #{seller_bio}, #{seller_insta_url}, #{seller_email}, #{profile_img_url},
			#{bank_name}, #{account_number}, true
		)
	</insert>
	
	<select id="select" resultType="Seller" parameterType="long">
		SELECT <include refid="columns"/>
		FROM seller
		WHERE seller_id = #{seller_id}
	</select>
	
</mapper>