<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="User">
	
	<sql id="columns">
		user_id, id, password, user_name, user_email, user_nickname, profile_img_url, create_date, role_id
	</sql>
	
	<resultMap			type="User"							id="roleMap">
		<id 					column="user_id"					property="user_id"/>
		<result				column="id"							property="id"/>
		<result				column="password"				property="password"/>
		<result				column="user_name"				property="user_name"/>
		<result				column="user_email"				property="user_email"/>
		<result				column="user_nickname"		property="user_nickname"/>
		<result				column="profile_img_url"		property="profile_img_url"/>
		<result				column="create_date"			property="create_date"/>
		<association	column="role_id"					property="role"					javaType="Role"		select="Role.select"/>
	</resultMap>
	
	<select id="selectAll" resultMap="roleMap">
		SELECT <include refid="columns"/> FROM user
	</select>
	
	<select id="select" resultMap="roleMap" parameterType="int">
		SELECT <include refid="columns"/> FROM user WHERE user_id=#{user_id}
	</select>
	
	<select id="selectByRoleId" resultMap="roleMap" parameterType="int">
		SELECT <include refid="columns"/> FROM user WHERE role_id=#{role_id}
	</select>

	<insert id="insert" parameterType="User">
		insert into user(id, user_name, user_email, role_id, sns_provider_id)
		values(#{id}, #{user_name}, #{user_email}, 1, #{snsProvider.sns_provider_id})
	</insert>
	
</mapper>