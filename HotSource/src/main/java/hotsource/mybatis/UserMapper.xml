<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="User">
	
	<sql id="columns">
		user_id, id, password, salt, user_name, user_email, user_nickname, profile_img_url, create_date, role_id, sns_provider_id
	</sql>
	<resultMap				type="User"							id="roleMap">
		<id 						column="user_id"					property="user_id"/>
		<result				column="id"							property="id"/>
		<result				column="password"				property="password"/>
		<result				column="salt"						property="salt"/>
		<result				column="user_name"			property="user_name"/>
		<result				column="user_email"			property="user_email"/>
		<result				column="user_nickname"		property="user_nickname"/>
		<result				column="profile_img_url"		property="profile_img_url"/>
		<result				column="create_date"			property="create_date"/>
		<result				column="salt"			property="salt"/>
		<association	column="role_id"					property="role"				javaType="Role"				select="Role.select"/>
		<association	column="sns_provider_id"	property="snsProvider"		javaType="SnsProvider"	select="SnsProvider.select"/>
	</resultMap>
	
	<select id="selectAll" resultMap="roleMap">
		SELECT <include refid="columns"/> FROM user
	</select>
	
	<select id="select" resultMap="roleMap" parameterType="long">
		SELECT <include refid="columns"/> FROM user WHERE user_id=#{user_id}
	</select>
	
	<select id="selectById" parameterType="String" resultMap="roleMap">
		SELECT <include refid="columns"/> FROM user WHERE id = #{id}
	</select>
	
	<select id="selectByEmail" parameterType="String" resultMap="roleMap">
		SELECT <include refid="columns"/> FROM user WHERE user_email = #{user_email}
	</select>
	
	<select id="selectByRoleId" resultMap="roleMap" parameterType="long">
		SELECT <include refid="columns"/> FROM user WHERE role_id=#{role_id}
	</select>

	<insert id="insert" parameterType="User">
		INSERT INTO user(id, user_name, user_email, password, user_nickname, salt, role_id, sns_provider_id)
		VALUES (#{id}, #{user_name}, #{user_email}, #{password}, #{user_nickname}, #{salt}, 1, #{snsProvider.sns_provider_id})
	</insert>
	
	<update id="updateBasic" parameterType="User">
		UPDATE user
		SET 	user_nickname=#{user_nickname}, profile_img_url=#{profile_img_url}
		WHERE user_id=#{user_id}
	</update>
	
	<update id="updateKeyword" parameterType="User">
	<!-- 키워드 매핑 테이블 -->
	</update>
		
	<update id="updatePassword" parameterType="User">
		UPDATE user
		SET 	password=#{password}, salt=#{salt}
		WHERE user_id=#{user_id}
	</update>
	

</mapper>