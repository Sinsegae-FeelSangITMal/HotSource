<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="AssetListItem">

    <!-- 공통 컬럼 정의 -->
    <sql id="columns">
        asset_list_item_id, list_order, asset_id, asset_list_id
    </sql>

    <!-- ResultMap: Asset, AssetList는 ID만 매핑 -->
    <resultMap id="AssetListItemResultMap" type="AssetListItem">
        <id property="asset_list_item_id" column="asset_list_item_id"/>
        <result property="list_order" column="list_order"/>

        <association property="asset" javaType="Asset">
            <id property="asset_id" column="asset_id"/>
        </association>

        <association property="assetList" javaType="AssetList">
            <id property="asset_list_id" column="asset_list_id"/>
        </association>
    </resultMap>

    <!-- 1. 전체 조회 -->
    <select id="selectAll" resultMap="AssetListItemResultMap">
        SELECT <include refid="columns"/>
        FROM asset_list_item
    </select>

    <!-- 2. 특정 리스트의 항목들 조회 -->
    <select id="selectByAssetListId" parameterType="long" resultMap="AssetListItemResultMap">
        SELECT <include refid="columns"/>
        FROM asset_list_item
        WHERE asset_list_id = #{asset_list_id}
        ORDER BY list_order ASC
    </select>

    <!-- 3. 단일 항목 조회 -->
    <select id="select" parameterType="long" resultMap="AssetListItemResultMap">
        SELECT <include refid="columns"/>
        FROM asset_list_item
        WHERE asset_list_item_id = #{asset_list_item_id}
    </select>

    <!-- 4. 등록 -->
    <insert id="insert" parameterType="AssetListItem">
        INSERT INTO asset_list_item (list_order, asset_id, asset_list_id)
        VALUES (
            #{list_order},
            #{asset.asset_id},
            #{assetList.asset_list_id}
        )
    </insert>

    <!-- 5. 수정 -->
    <update id="update" parameterType="AssetListItem">
        UPDATE asset_list_item
        SET list_order = #{list_order},
            asset_id = #{asset.asset_id},
            asset_list_id = #{assetList.asset_list_id}
        WHERE asset_list_item_id = #{asset_list_item_id}
    </update>

    <!-- 6. 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM asset_list_item
        WHERE asset_list_item_id = #{asset_list_item_id}
    </delete>

    <!-- 7. 리스트 내 전체 항목 삭제 -->
    <delete id="deleteByAssetListId" parameterType="long">
        DELETE FROM asset_list_item
        WHERE asset_list_id = #{asset_list_id}
    </delete>

</mapper>
