<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Ordered">
	
	<sql id="columns">
		order_id, order_no, order_date, order_state, total_price, total_pay, user_id
	</sql>
	
	<resultMap 			type="Ordered" 					id="joinOrderMap">
		<id 				column="order_id" 			property="order_id"/>
		<result 			column="order_no" 			property="order_no"/>
		<result 			column="order_date" 		property="order_date"/>
		<result 			column="order_state" 		property="order_state"/>
		<result 			column="total_price" 		property="total_price"/>
		<result 			column="total_pay" 			property="total_pay"/>
		<association 	column="user_id" 				property="user" 	javaType="User" select="User.select"/>
	</resultMap>
	
	<select id="selectAll" resultMap="joinOrderMap">
		SELECT <include refid="columns"/> FROM ordered
	</select>
	
	<select id="select" resultMap="joinOrderMap" parameterType="long">
		SELECT <include refid="columns"/> FROM ordered WHERE order_id=#{order_id}
	</select>
	
	<select id="selectByUserId" resultMap="joinOrderMap" parameterType="long">
		SELECT <include refid="columns"/> FROM ordered WHERE user_id=#{user_id}
	</select>
	
	<!-- 구매 여부: exists 결과가 하나라도 있으면 true, 아니면 false반환 -->
	<select id="existsByUserIdAndAssetId" parameterType="map" resultType="boolean">
		SELECT EXISTS (
	    	SELECT 1
	    	FROM ordered o
	    	JOIN ordered_asset oa ON o.order_id = oa.order_id
	    	WHERE o.user_id = #{user_id}
	      	AND oa.asset_id = #{asset_id}
	  	)
</select>
	
</mapper>