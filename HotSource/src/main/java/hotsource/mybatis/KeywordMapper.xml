<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Keyword">
	
	<sql id="columns">
		keyword_id, keyword_name
	</sql>
	
	<select id="selectAll" resultType="Keyword">
		SELECT <include refid="columns"/> FROM keyword
	</select>
	
	<select id="select" resultType="Keyword" parameterType="long">
		SELECT <include refid="columns"/> FROM keyword WHERE keyword_id=#{keyword_id}
	</select>
	
	<select id="selectByName" resultType="Keyword" parameterType="String">
		SELECT <include refid="columns"/> FROM keyword WHERE keyword_name=#{keyword_name}
	</select>
	
	<insert id="insert" parameterType="Keyword">
		insert IGNORE into keyword(keyword_name) values (#{keyword_name})
		<selectKey keyColumn="keyword_id" keyProperty="keyword_id" resultType="long" order="AFTER">
			select last_insert_id() as keyword_id
		</selectKey>
	</insert>
	
</mapper>