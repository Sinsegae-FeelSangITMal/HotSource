<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Cart">
	
	<sql id="columns">
		cart_id, create_date, asset_id, user_id
	</sql>
	
	<resultMap 		type="Cart" 					id="joinMap">
		<id 					column="cart_id" 			property="cart_id"/>
		<result 			column="create_date" 	property="create_date"/>
		<association 	column="asset_id" 		property="asset" 			javaType="Asset" 		select="Asset.select"/>
		<association 	column="user_id" 		property="user" 			javaType="User" 		select="User.select"/>
	</resultMap>
	
	<select id="selectAll" resultMap="joinMap">
		SELECT <include refid="columns"/> FROM cart
	</select>
	
	<select id="select" resultMap="joinMap" parameterType="int">
		SELECT <include refid="columns"/> FROM cart WHERE cart_id=#{cart_id}
	</select>
	
	<select id="selectByUserId" resultMap="joinMap" parameterType="int">
		SELECT <include refid="columns"/> FROM cart WHERE user_id=#{user_id}
	</select>
	
</mapper>