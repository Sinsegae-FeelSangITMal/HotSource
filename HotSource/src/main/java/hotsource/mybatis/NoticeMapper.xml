<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Notice">
	
	<sql id="columns">
		notice_id, title, content, create_date  <!-- notice_img_url ,seller_id -->
	</sql>

	<select id="selectAll" resultType="Notice">
		select <include refid="columns"/> from notice				
	</select>
	
	<select id="select" parameterType="long" resultType="Notice">
		select <include refid="columns"/> from notice where notice_id=#{notice_id}	
	</select>
	
	<insert id="insert" parameterType="Notice">
		insert into notice(title, seller_id, content) values(#{title}, 1, #{content})
	</insert>
	
	<update id="update" parameterType="Notice">
		update notice set title=#{title}, seller_id=#{seller.seller_id}, content=#{content}
		where notice_id=#{notice_id}
	</update>
	
	<delete id="delete" parameterType="long">
		delete from notice where notice_id=#{notice_id}
	</delete>
	
</mapper>